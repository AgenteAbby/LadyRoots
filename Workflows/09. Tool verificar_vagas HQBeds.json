      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [400, 0]
    },
    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data || '';\nconst regex = /name=\"units\\[(\\d+)\\]\\[serialized_price_info\\]\"\\s*value=\"([^\"]+)\"/g;\nlet match; let achou = false;\nlet md = \"🏨 **RESULTADO DA BUSCA DE VAGAS**\\n\\n\";\nconst nomes = [{id: 'Aventureiro', nome: 'Suíte Aventureiro'}, {id: 'Lagoa Azul', nome: 'Suíte Lagoa Azul'}, {id: 'Pico do Papagaio', nome: 'Pico do Papagaio'}];\n\nwhile ((match = regex.exec(html)) !== null) {\n  achou = true;\n  const idQ = match[1]; const token = match[2];\n  let nomeId = \"Quarto Standard (ID \"+idQ+\")\";\n  for (let n of nomes) { if(html.includes(n.id)) { nomeId = n.nome; break; } }\n  md += `✅ **${nomeId}**\\n- **ID para Reserva:** \\`${idQ}\\`\\n- **Token Serializado:** \\`${token}\\`\\n\\n`;\n}\n\nif (!achou) {\n  md = \"❌ **Nenhuma vaga encontrada** para as datas solicitadas.\\nSugira ao cliente tentar outras.\";\n} else {\n  md += \"---\\n📌 **INSTRUÇÃO PARA A IA:**\\nCopie o `ID` e toda a string do `Token` fornecidos acima, peça os dados do hóspede, e envie tudo chamando a ferramenta `criar_reserva`.\";\n}\n\nreturn { json: { dados_markdown_para_ia: md } };"
      },
      "id": "parser-html",
      "name": "Gerar Resumo em MD",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [600, 0]
    }
